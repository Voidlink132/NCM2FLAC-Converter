<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.ncm2flac.converter">

    <!-- NCM转FLAC核心必备权限，全Android版本适配 -->
    <!-- 基础权限：安装即授予，无需动态申请 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- 需动态申请的危险权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 存储权限全版本适配：覆盖Android 5.0 ~ Android 14 -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <!-- 应用核心配置，完全兼容AGP 8.0+ 规范 -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ncm2Flac"
        android:usesCleartextTraffic="false"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="34">

        <!-- 主启动Activity：应用入口，配置错误会导致无桌面图标/无法启动 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <!-- 桌面启动入口，两个标签缺一不可 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 支持文件管理器直接打开.ncm文件唤起应用 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.ncm" />
                <data android:pathPattern=".*\\.NCM" />
            </intent-filter>
        </activity>

        <!-- 音频转换前台服务：防止转换大文件时被系统杀死，无对应服务可直接删除此标签 -->
        <service
            android:name=".service.AudioConvertService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            tools:targetApi="34" />

    </application>

</manifest>
